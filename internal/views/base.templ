package views

templ base(title string) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>{ title }</title>
			<link rel="stylesheet" href="/static/css/main.css"/>
			<script src="/static/js/htmx.min.js"></script>
		</head>
		<body>
			<header>
				<h1>{ title }</h1>
			</header>
			<main>
				{ children... }
			</main>
			<footer></footer>
		</body>
	</html>
}
